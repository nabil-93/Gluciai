{
  "expo": {
    "name": "GlucoAI",
    "slug": "glucoai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "glucoai",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#101014",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.nabil.glucoai",
      "infoPlist": {
        "NSCameraUsageDescription": "GlucoAI uses the camera to analyze your meals with AI.",
        "NSPhotoLibraryUsageDescription": "GlucoAI lets you import meal photos for AI analysis."
      }
    },
    "android": {
      "package": "com.nabil.glucoai",
      "adaptiveIcon": {
        "backgroundColor": "#101014",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#101014",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-localization",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "GlucoAI uses the camera to analyze your meals with AI."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
