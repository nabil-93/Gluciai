{
  "expo": {
    "name": "GluciAI",
    "slug": "glucoai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "glucoai",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#101014",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.nabil.glucoai",
      "infoPlist": {
        "NSCameraUsageDescription": "GluciAI uses the camera to analyze your meals with AI.",
        "NSPhotoLibraryUsageDescription": "GluciAI lets you import meal photos for AI analysis."
      }
    },
    "android": {
      "package": "com.nabil.glucoai",
      "adaptiveIcon": {
        "backgroundColor": "#101014",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#101014",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-localization",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "GluciAI uses the camera to analyze your meals with AI."
        }
      ],
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "organization": "glucoai",
          "project": "glucoai-app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f42952af-b211-45f4-bcc4-5194087ab3b5"
      }
    },
    "owner": "tsuhel"
  }
}
