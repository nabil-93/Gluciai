# Copy to .env and fill with your Supabase project values (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — production USDA quota (else DEMO_KEY, rate-limited)
#   free key: https://fdc.nal.usda.gov/api-key-signup.html
EXPO_PUBLIC_USDA_API_KEY=

# ── AI / provider keys are NOT set here ────────────────────────────────
# They live server-side as Supabase secrets. Set them with:
#   bash scripts/deploy-supabase.sh <project-ref>
# after exporting the ones you use:
#   GEMINI_API_KEY            (required — meal scanner vision)
#   OPENAI_API_KEY            (optional — ai-chat assistant)
#   FATSECRET_CLIENT_ID / FATSECRET_CLIENT_SECRET   (optional provider)
#   EDAMAM_APP_ID / EDAMAM_APP_KEY                  (optional provider)
